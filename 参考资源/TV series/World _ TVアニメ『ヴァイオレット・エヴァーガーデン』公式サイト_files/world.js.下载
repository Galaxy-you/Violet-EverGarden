var $mapBtn = $('.worldMapBtn');
var $listBtn = $('.worldListBtn');
var $spot = $('.spotDetailBox');
var $spotFr = $('.spotDetailFrame');
var $spotClose = $('.spotCloseBtn');

$mapBtn.on('click', function(){ var index = $mapBtn.index(this); spotDetailOpen(index); });
$listBtn.on('click', function(){ var index = $listBtn.index(this); spotDetailOpen(index); });

$spot.on('click', spotDetailClose);
$spotClose.on('click', spotDetailClose);
$spotFr.on('click', spotDetailCloseStop);

function spotDetailOpen(index){
	var spot = $spot.eq(index);
	spot.stop().scrollTop(0).fadeIn(0).children('.spotDetailFrame').animate({top:'0%'},400,'easeOutCubic');

	return false;
}
function spotDetailClose(){
	$spot.children('.spotDetailFrame').stop().animate({top:'100%'},400,'easeOutCubic');
	$spot.scrollTop(0).stop().delay(200).fadeOut(500);
	return false;
}
function spotDetailCloseStop(e){
	e.stopPropagation();
}
