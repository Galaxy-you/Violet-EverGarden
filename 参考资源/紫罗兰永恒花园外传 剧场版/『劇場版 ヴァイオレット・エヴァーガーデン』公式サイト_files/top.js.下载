	
	//映像のサイズ調整
	function movieSet(wW) {
		var curH = 1080*wW/1920;
		$('.movieBox,#youtubeBgMovie').css({'width':wW+'px','height':curH+'px'});
	}
	
	//リサイズ --> 映像のサイズ調整
	var timer = false;
	$(window).on('resize', function() {
		if (timer !== false) { clearTimeout(timer); }
		timer = setTimeout(function() {
			if ($('#youtubeBgMovie').is(':visible')) {
				var wW = $('.info').width();
				movieSet(wW);
			}
		}, 200);
	});
	
		//Magnific Popup -----ajax
	$('.ajaxPopup').magnificPopup({type: 'ajax',mainClass:"mfp-fade",overflowY: 'scroll'
	});
	
	//load event
	jQuery.event.add(window,"load",function() {
		if ($('#youtubeBgMovie').is(':visible')) {
			var wW = $('.info').width();
			movieSet(wW);
		}
		$('#overlay').fadeOut(800);
