	$(function(){
		var delay = 7000;      // 表示時間
		var fade = 680;        // フェードスピード
		var timerId;
			// スライドの１枚目を表示
			$(".kvSlider .slideList li:first").show();
			// １枚目のプログレスバー
			$(".kvSlider .progressBarBox .progressBar").stop().css("width","0px").animate({width:"100%"}, delay, "linear");
			// スライドの枚数を取得
			var slideIndex = $(".kvSlider .slideList li").length - 1;
			var imgNo = 0;

			// 一定間隔で処理を繰り返す
			timerId = setInterval(function(){
// スライドショー
            if(imgNo < slideIndex){
                $(".kvSlider .slideList li").eq(imgNo).fadeOut(fade).queue(function () {
						  imgNo ++;
                    $(".kvSlider .slideList li").eq(imgNo).fadeIn(fade).dequeue();
                });
            } else if(imgNo === slideIndex){
                $(".kvSlider .slideList li").eq(imgNo).fadeOut(fade).queue(function () {
                     imgNo = 0;
                    $(".kvSlider .slideList li:first-child").fadeIn(fade).dequeue();
                });
            } 
				// プログレスバー
				$(".kvSlider .progressBarBox .progressBar").stop().delay(680).css("width","0px").animate({width:"100%"}, 6320, "linear");
			}, delay);
	});
