	//映像のサイズ調整
	function movieSet(wW) {
		var curH = 1080*wW/1920;
		if(wW <= 1200){wW = 1200;curH = 600;}else{curH = curH;}
		$('#youtubeBgMovie').css({'width':wW+'px','height':curH+'px'});
	}

	//リサイズ --> 映像のサイズ調整
	var timer = false;
	$(window).on('load resize', function() {
		if (timer !== false) { clearTimeout(timer); }
		timer = setTimeout(function() {
			if ($('#youtubeBgMovie').is(':visible')) {
				var wW = $(document).width();
				movieSet(wW);
			}
		}, 200);
	});

	//背景固定画像切替
	function changeClass() {
		if( $('.music').length > 0 ) {
			var value = $(this).scrollTop();
			if ( value > $('.music').offset().top ) {
				$('.bgFixed').addClass('switching');
			} else {
				$('.bgFixed').removeClass('switching');
			}
		}
	}

	$(window).on('scroll', function() {
		changeClass()
	});

		//load event
	jQuery.event.add(window,"load",function() {
		$('#overlay').fadeOut(800);
		changeClass()

	});


